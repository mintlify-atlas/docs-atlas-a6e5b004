  "keyFeatures": [
    "RestClient for spot trading, margin, account management, and earn products",
    "FuturesClientV2 for USD-M perpetual futures with V2 domain support",
    "Unified WebsocketClient for real-time spot and futures data streams",
    "Automatic WebSocket reconnection with topic resubscription",
    "Full TypeScript support with strongly-typed requests and responses",
    "Browser-compatible HMAC signing via Web Crypto API",
    "Demo/simulated trading environment support for futures",
    "ESM and CJS dual builds with a single npm package",
    "Custom HMAC sign function injection for improved performance",
    "Configurable recvWindow globally or per-request"
  ],
  "publicApiSurface": [
    "RestClient",
    "FuturesClientV2",
    "WebsocketClient",
    "RestClientOptions",
    "WSClientConfigurableOptions",
    "WsMarket",
    "WsTopic",
    "WsKey",
    "APIResponse",
    "subscribe(topics, market)",
    "unsubscribe(topics, market)",
    "subscribeTopics(topics)",
    "unsubscribeTopics(topics)",
    "connectAll()",
    "getSpotTickersV3()",
    "getSpotHistoryKlineV3()",
    "submitSpotOrderV2()",
    "cancelSpotOrderV3()",
    "getAccountBalancesV1()",
    "getFuturesContractDetails()",
    "getFuturesAccountAssets()",
    "submitFuturesOrder()",
    "setFuturesLeverage()",
    "submitFuturesTPSLOrder()",
    "submitFuturesPlanOrder()"
  ]
